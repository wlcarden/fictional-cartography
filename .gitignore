# Cached upstream data — re-fetched on first render
cache/srtm/*.hgt
cache/overpass/*.json
cache/density/*.npy
cache/water/*.npy
cache/boundaries/*.json
cache/stages/*

# Rendered outputs
output/*.png
output/*.jpg
output/*.jpeg
output/*.webp
output/*.tiff
output/*.tif
output/*.pdf

# Render-page preview thumbnails. PREVIEW_DIR (web/_previews/) is
# regenerated by the server on demand; nothing in there should be
# committed. Keep the directory itself via .gitkeep so the server's
# mkdir(parents=True) is a no-op on a fresh checkout.
web/_previews/*
!web/_previews/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Editor / tooling state
.claude/
.vscode/
.idea/
*.swp
*~
.DS_Store

# OS
Thumbs.db

# Manual backup files (stale snapshots, not the test-driven backup
# system in tests/playwright/helpers.py which writes to /tmp).
*.original
*.bak
*.orig
